<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap3 com rescap">

  <Identity
    Name="Vallhalen.ClaudePeakHours"
    Publisher="CN=Vallhalen"
    Version="1.0.0.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Claude Peak Hours</DisplayName>
    <PublisherDisplayName>Vallhalen</PublisherDisplayName>
    <Description>Peak/off-peak status for Claude AI usage limits</Description>
    <Logo>Images\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
    <Resource Language="pl" />
  </Resources>

  <Applications>
    <Application Id="App"
      Executable="ClaudePeakWidget.exe"
      EntryPoint="Windows.FullTrustApplication">

      <uap:VisualElements
        DisplayName="Claude Peak Hours"
        Description="Peak/off-peak hours indicator for Claude AI"
        Square150x150Logo="Images\Square150x150Logo.png"
        Square44x44Logo="Images\Square44x44Logo.png"
        BackgroundColor="transparent">
        <uap:DefaultTile Wide310x150Logo="Images\Wide310x150Logo.png" />
      </uap:VisualElements>

      <Extensions>
        <!-- COM server registration -->
        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <com:ExeServer Executable="ClaudePeakWidget.exe" DisplayName="Claude Peak Widget Provider">
              <com:Class Id="E5B3F02A-7B7E-4A5D-9C1F-8D2E6A3B4C5D" DisplayName="ClaudePeakWidgetProvider" />
            </com:ExeServer>
          </com:ComServer>
        </com:Extension>

        <!-- Widget provider registration -->
        <uap3:Extension Category="windows.appExtension">
          <uap3:AppExtension Name="com.microsoft.windows.widgets"
                             DisplayName="Claude Peak Hours"
                             Id="ClaudePeakHours"
                             PublicFolder="Public">
            <uap3:Properties>
              <WidgetProvider>
                <ProviderIcons>
                  <Icon Path="Images\Square44x44Logo.png" />
                </ProviderIcons>
                <Activation>
                  <CreateInstance ClassId="E5B3F02A-7B7E-4A5D-9C1F-8D2E6A3B4C5D" />
                </Activation>
                <Definitions>
                  <Definition Id="ClaudePeakHours"
                              DisplayName="Claude Peak Hours"
                              Description="Peak/off-peak status for Claude AI">
                    <Capabilities>
                      <Capability>
                        <Size Name="small" />
                      </Capability>
                      <Capability>
                        <Size Name="medium" />
                      </Capability>
                      <Capability>
                        <Size Name="large" />
                      </Capability>
                    </Capabilities>
                    <ThemeResources>
                      <Icons>
                        <Icon Path="Images\Square44x44Logo.png" />
                      </Icons>
                    </ThemeResources>
                  </Definition>
                </Definitions>
              </WidgetProvider>
            </uap3:Properties>
          </uap3:AppExtension>
        </uap3:Extension>
      </Extensions>

    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>

</Package>
